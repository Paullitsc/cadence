# Copy to .env and fill in as each phase requires. Phase 0 needs NO secrets.
# Never commit your real .env (it is git-ignored).

# --- Core (Phase 0+) ---
LOG_LEVEL=INFO
STORAGE_BACKEND=sqlite          # sqlite (local, default) | supabase
DATABASE_PATH=data/pipeline.db
COMPANIES_FILE=companies.yaml

# --- Phase 1: sourcing ---
ENABLE_SIMPLIFY=true            # pull SimplifyJobs listings.json
# SIMPLIFY_LISTINGS_URL=        # override the default raw listings.json URL
DIGEST_DIR=data/digests         # where the daily HTML digest is written

# Phase 1 (optional) Supabase Postgres — used only if STORAGE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_KEY=

# Phase 1 (optional) JSearch / RapidAPI tertiary source. Free tier = 200 req/mo.
ENABLE_JSEARCH=false            # leave false unless you set RAPIDAPI_KEY
RAPIDAPI_KEY=
# JSEARCH_QUERY=software engineer intern

# --- Phase 2+ : Anthropic API (Claude Haiku 4.5) for matching / tailoring / drafting ---
# Obtain from the Anthropic Console (see ACTIONS_FOR_PAUL.md). Maps to: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=

# --- Future phases (config names reserved; NOT used yet — leave blank) ---
# HUNTER_API_KEY=          # Phase 3 contact lookup
# APOLLO_API_KEY=          # Phase 3 contact lookup
# GMAIL_OAUTH_TOKEN_JSON=  # Phase 3/4 Gmail send + reply scan
# SLACK_WEBHOOK_URL=       # Phase 4 failure alerts
