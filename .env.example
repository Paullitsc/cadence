# Copy to .env and fill in as each phase requires. Phase 0 needs NO secrets.
# Never commit your real .env (it is git-ignored).

# --- Core (Phase 0+) ---
LOG_LEVEL=INFO
STORAGE_BACKEND=sqlite          # sqlite (local, default) | supabase
DATABASE_PATH=data/pipeline.db
COMPANIES_FILE=companies.yaml

# --- Phase 1: sourcing ---
ENABLE_SIMPLIFY=true            # pull SimplifyJobs listings.json
# SIMPLIFY_LISTINGS_URL=        # override the default raw listings.json URL
DIGEST_DIR=data/digests         # where the daily HTML digest is written

# Phase 1 (optional) Supabase Postgres — used only if STORAGE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_KEY=

# Phase 1 (optional) JSearch / RapidAPI tertiary source. Free tier = 200 req/mo.
ENABLE_JSEARCH=false            # leave false unless you set RAPIDAPI_KEY
RAPIDAPI_KEY=
# JSEARCH_QUERY=software engineer intern

# --- Phase 2 : résumé slicing + application drafting ---
# Anthropic API (Claude Haiku 4.5) for tailoring / answers. Obtain from the
# Anthropic Console (see ACTIONS_FOR_PAUL.md). Without it, tailoring falls back to
# deterministic select-only and answer drafting is skipped — the pipeline still runs.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5   # swap the model without touching code
# ANTHROPIC_MAX_TOKENS=2048

# Tagged master résumé (single source of truth). Replace the shipped placeholder.
# MASTER_RESUME_FILE=master_resume.yaml

# Embeddings. sentence_transformers (default, local/free) or hashing (deterministic
# fallback, no deps). Falls back to hashing automatically if the lib is missing.
# EMBEDDING_BACKEND=sentence_transformers
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Scoring / retrieval knobs (tune to taste).
# TOP_K_BULLETS=8
# MAX_TAILORED_BULLETS=10
# FIT_SCORE_THRESHOLD=0.30          # below this, no application is prepared
# HIGH_PRIORITY_THRESHOLD=0.55      # at/above this, human_review is flagged
# MAX_APPLICATIONS_PER_RUN=15       # cost guard: only the top-N by fit get LLM+PDF per run
# TARGET_COMPANIES=                 # comma-separated always-high-priority companies
# RESUME_OUTPUT_DIR=data/resumes

# --- Phase 3: cold outreach (drafting is automatic; SENDING is always manual) ---
# Contact lookup providers. BOTH default off — with neither enabled, every contact
# is a free, unverified company email-pattern GUESS and the stage stays fully offline.
# ENABLE_HUNTER=false
# HUNTER_API_KEY=                   # Hunter.io key (free tier ~25-50 searches/mo)
# ENABLE_APOLLO=false
# APOLLO_API_KEY=                   # Apollo.io key (free tier ~100 credits/mo)
# Free-tier guard: cap on billable lookups per run, reserved for high-priority roles.
# OUTREACH_MAX_LOOKUPS_PER_RUN=5
# OUTREACH_PAID_LOOKUP_HIGH_PRIORITY_ONLY=true

# CAN-SPAM footer (REQUIRED before any email can be sent): honest sender identity, a
# REAL physical mailing address, and a working opt-out. The send gate REFUSES to send
# while the address is still the REPLACE_ME placeholder.
# OUTREACH_FROM_NAME=Your Name
# OUTREACH_FROM_EMAIL=you@example.com
# OUTREACH_PHYSICAL_ADDRESS=123 Real St, City, Country      # CAN-SPAM requires a real one
# OUTREACH_OPT_OUT=                 # opt-out text; blank = a sensible default
# OUTREACH_SUPPRESSION_FILE=        # optional seed file of emails/domains to never contact

# Gmail (manual `approve-and-send`, the digest email, the reply scan, the failure alert).
# Mint the token ONCE (send + readonly scopes) via: python -m internship_pipeline.outreach.gmail_auth
# GMAIL_CREDENTIALS_JSON=           # OAuth client-secrets JSON (one-time auth only)
# GMAIL_OAUTH_TOKEN_JSON=           # authorized-user token JSON everything Gmail reads

# --- Phase 4: orchestration, digest email, reply scan, alerts ---
# Dual-trigger: high-fit AND favorable → prepare BOTH an application and outreach. Favorable
# = a TARGET_COMPANIES name OR posted within FAVORABLE_RECENT_DAYS (proxy for "deadline soon").
# FAVORABLE_RECENT_DAYS=7
# Morning digest email — sending TO YOURSELF is safe to automate (needs Gmail, above).
# DIGEST_EMAIL_ENABLED=false
# DIGEST_TO_EMAIL=                  # defaults to OUTREACH_FROM_EMAIL (yourself)
# DIGEST_TOP_N=10
# Recruiter-reply scan (best-effort Gmail search shown in the digest).
# REPLY_SCAN_DAYS=14
# REPLY_SCAN_QUERY=                 # extra Gmail search terms, e.g. "subject:interview"
# Failure alert channel. email is implemented (Gmail); slack is a documented stub.
# ALERT_CHANNEL=email
# SLACK_WEBHOOK_URL=                # only used if ALERT_CHANNEL=slack (stub)

# --- Phase 5: Google Sheets tracker + Drive CV store + Gmail outreach drafts ---
# The application workspace: one sheet row per prepared application, with a durable
# Drive link to the tailored CV. All optional — unset, the sync stage no-ops.
# TRACKER_SHEETS_ENABLED=false
# GOOGLE_SERVICE_ACCOUNT_JSON=      # path to the service-account key file (or inline JSON)
# SHEETS_SPREADSHEET_ID=            # the tracker spreadsheet id (shared with the SA)
# DRIVE_FOLDER_ID=                  # Drive folder for tailored-CV PDFs (shared with the SA)
# CV grouping (LLM cost saver): jobs whose JD embeddings are at least this similar
# share ONE tailored CV; keyword overlap is the sanity check.
# CV_GROUP_SIMILARITY=0.9
# CV_GROUP_KEYWORD_OVERLAP=0.5
# Real ATS form questions: cap on answer-drafting LLM calls per run (only jobs
# with visible Greenhouse free-text questions; fetches are free).
# MAX_QUESTION_DRAFTS_PER_RUN=15
# Real Gmail DRAFTS for outreach (edit + send from Gmail; still never auto-sent).
# Needs the gmail.compose scope — re-run gmail_auth after enabling this flag.
# OUTREACH_GMAIL_DRAFTS_ENABLED=false
