<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Internship digest — {{ generated_at.strftime('%Y-%m-%d') }}</title>
  <style>
    body { font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
           color: #1a1a1a; max-width: 820px; margin: 24px auto; padding: 0 16px; }
    h1 { font-size: 20px; margin-bottom: 2px; }
    .meta { color: #666; font-size: 13px; margin-bottom: 16px; }
    h2 { font-size: 15px; margin: 24px 0 6px; border-bottom: 1px solid #eee; padding-bottom: 4px; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    td { padding: 4px 8px 4px 0; vertical-align: top; }
    td.meta2, .meta2 { color: #888; font-size: 12px; }
    a { color: #1155cc; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .empty { color: #666; font-style: italic; }
    .pill { display: inline-block; font-size: 11px; padding: 1px 6px; border-radius: 10px;
            background: #eef; color: #335; margin-left: 6px; }
    .warn { color: #a15c00; }
    .ok { color: #0a7d33; }
    code { background: #f4f4f4; padding: 1px 4px; border-radius: 3px; font-size: 12px; }
    .hint { color: #666; font-size: 12px; margin: 2px 0 8px; }
    .stats { font-size: 14px; margin: 12px 0; }
    .stats b { font-variant-numeric: tabular-nums; }
    .tracker { display: inline-block; margin: 6px 0 4px; padding: 8px 14px; border-radius: 6px;
               background: #e8f0fe; font-weight: 600; }
    pre.draft { background: #f8f8f8; border: 1px solid #eee; border-radius: 4px; padding: 8px 10px;
                white-space: pre-wrap; font-size: 12.5px; margin: 6px 0 10px; }
    footer { margin-top: 28px; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <h1>Internship digest — {{ generated_at.strftime('%Y-%m-%d') }}</h1>
  <div class="meta">{{ generated_at.strftime('%Y-%m-%d %H:%M UTC') }} · run <code>{{ run_id }}</code></div>

  {# --- Compact header: the counts; the SHEET is the application workspace. --- #}
  <div class="stats">
    <b>{{ counts.get('new', 0) }}</b> new jobs ·
    <b>{{ counts.get('applications_prepared', 0) }}</b> applications prepared ·
    <b>{{ counts.get('llm_calls_saved', 0) }}</b> LLM calls saved (CV grouping)
  </div>
  {% if counts.get('applications_pending', 0) %}
  <p class="hint"><b>{{ counts.get('applications_pending', 0) }}</b> application(s) are waiting
    for your CV review — run <code>make review</code> to pick the bullets, check the one-page
    fit, and push them to the sheet.</p>
  {% endif %}
  {% if sheet_url %}
  <a class="tracker" href="{{ sheet_url }}">Open the application tracker (Google Sheet) →</a>
  <p class="hint">Every application you reviewed is a row there: job link, tailored CV (Drive),
    drafted answers, and your status/notes workflow. Submitting is always your click.</p>
  {% else %}
  <p class="hint">Tracker sheet not configured — applications live in storage
    (see ACTIONS_FOR_PAUL.md to set up the Google Sheet).</p>
  {% endif %}

  {# --- Networking ladder (Phase 6): drafted by the pipeline, sent by the human. --- #}
  {% if networking_actions or counts.get('networking_awaiting_person', 0) %}
  <h2>Networking — today's LinkedIn actions</h2>
  <p class="hint">Copy each draft into LinkedIn by hand, then flip the row's Status on the
    sheet's <b>Networking</b> tab. LinkedIn is never automated.</p>
  {% if networking_actions %}
  <table>
    {% for a in networking_actions[:20] %}
    <tr>
      <td class="meta2">{{ a.kind }}</td>
      <td>{{ a.person.company_name }}{% if a.person.name %} — {{ a.person.name }}{% endif %}
        {%- if a.person.role %} <span class="meta2">({{ a.person.role }})</span>{% endif %}
        {% if a.person.linkedin_url %} · <a href="{{ a.person.linkedin_url }}">profile</a>{% endif %}
        <div class="meta2">{{ a.instruction }}</div>
        {% if a.person.draft_body %}<pre class="draft">{{ a.person.draft_body }}</pre>{% endif %}
      </td>
    </tr>
    {% endfor %}
  </table>
  {% if networking_actions|length > 20 %}
  <p class="hint">+{{ networking_actions|length - 20 }} more on the Networking tab.</p>
  {% endif %}
  {% else %}
  <p class="empty">Nothing due today.</p>
  {% endif %}
  {% if counts.get('networking_awaiting_person', 0) %}
  <p class="hint"><b>{{ counts.get('networking_awaiting_person', 0) }}</b> target companies still
    need a person picked — fill Person + LinkedIn on the Networking tab (company pages are linked).</p>
  {% endif %}
  {% endif %}

  {# --- Outreach drafts awaiting approval — the inbox's real job. --- #}
  <h2>Outreach drafts awaiting your approval</h2>
  {% if pending_outreach %}
  <p class="hint">Edit + send from Gmail where a draft link is shown, or use
    <code>python -m internship_pipeline.outreach.approve_and_send &lt;id&gt; --yes</code>.
    LinkedIn notes are draft-only — send those yourself.</p>
  <table>
    {% for o in pending_outreach %}
    <tr>
      <td class="meta2">{{ o.channel }}</td>
      <td>{{ o.company_name }} — {{ o.title }}
        <span class="meta2">
          → {{ o.contact_name or o.contact_email or 'no verified contact' }}
          {%- if o.contact_title %} ({{ o.contact_title }}){% endif %}
          {%- if o.contact_name and o.contact_email %} · {{ o.contact_email }}{% endif %}
          · {{ o.contact_source }}
          {%- if o.contact_verified %} · <span class="ok">verified</span>
          {%- else %} · <span class="warn">unverified</span>{% endif %}
        </span>
        {% if o.suppressed %}<span class="pill warn">suppressed</span>{% endif %}
        {% if o.gmail_draft_link %}
        <br><a href="{{ o.gmail_draft_link }}">✉ edit the draft in Gmail</a>
        {% endif %}
        <br><code>{{ o.outreach_id }}</code>
      </td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <p class="empty">No outreach drafts awaiting approval.</p>
  {% endif %}

  {# --- Possible recruiter replies (kept as-is). --- #}
  {% if replies %}
  <h2>Possible replies to review</h2>
  <p class="hint">Heuristic scan of recent inbound mail — not all are recruiter replies.</p>
  <table>
    {% for r in replies %}
    <tr>
      <td>{{ r.who }}<br><span class="meta2">{{ r.subject }}</span></td>
      <td class="meta2">{{ r.date }}</td>
    </tr>
    {% endfor %}
  </table>
  {% endif %}

  <footer>
    Generated by the internship pipeline. Everything here is <strong>pending your review</strong> —
    the system prepares; you send outreach and submit applications yourself.
  </footer>
</body>
</html>
